{
  "seed": 123,
  "paths": {
    "images_dir": "longoeixo/imgs",
    "split_path": "panorama_foundation/splits/ae_full999_split.json",
    "output_dir": "panorama_foundation/experiments/ae_full999"
  },
  "split": {
    "val_ratio": 0.15,
    "test_ratio": 0.0
  },
  "data": {
    "image_size": 256,
    "augment_train": true
  },
  "pretext": {
    "mode": "identity",
    "corruption_prob": 1.0,
    "apply_on_eval": true
  },
  "loss": {
    "focus_corrupted_regions": false,
    "w_corrupted": 0.8,
    "w_clean": 0.2
  },
  "model": {
    "backbone": "resnet34"
  },
  "training": {
    "device": "auto",
    "epochs": 60,
    "batch_size": 4,
    "num_workers": 0,
    "prefetch_factor": 2,
    "lr": 0.0003,
    "lr_min": 0.000001,
    "weight_decay": 0.0001,
    "amp": true,
    "loss_w_l1": 0.8,
    "loss_w_mse": 0.2,
    "early_stopping_patience": 5,
    "max_train_batches": 0,
    "max_val_batches": 0
  },
  "visuals": {
    "interval": 1,
    "max_samples": 6
  }
}
